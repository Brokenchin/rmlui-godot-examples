			<div class="color-box" style="background-color: #22aaaa;"></div>
			<div class="color-box" style="background-color: #aaaa22;"></div>
			<div class="color-box" style="background-color: #553333;"></div>
			<div class="color-box" style="background-color: #335533;"></div>
			<div class="color-box" style="background-color: #333355;"></div>
