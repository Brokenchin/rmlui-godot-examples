<rml>
<head>
	<title>Performance Stress Test</title>
	<link type="text/rcss" href="res://addons/rmlui-godot/base.rcss" />
	<style>
		body {
			background-color: #0d0d1a;
			font-family: "Noto Sans";
			font-size: 14px;
			color: #ffffff;
		}
		.container {
			padding: 8px;
		}
		h1 {
			font-size: 20px;
			margin-bottom: 8px;
			color: #e94560;
		}
		h2 {
			font-size: 16px;
			margin-top: 8px;
			margin-bottom: 4px;
			color: #a0c4ff;
		}

		/* --- Section: Simple List --- */
		.list-section {
			padding: 6px;
			background-color: #111128;
			margin-bottom: 8px;
		}
		.list-item {
			padding: 3px 6px;
			margin-bottom: 2px;
			background-color: #1a1a3a;
			color: #ccccee;
		}
		.list-item:hover {
			background-color: #2a2a5a;
			transition: background-color 0.15s;
		}

		/* --- Section: Nested Grid --- */
		.grid-section {
			padding: 6px;
			background-color: #0f1a2e;
			margin-bottom: 8px;
		}
		.grid-row {
			display: block;
			margin-bottom: 2px;
		}
		.grid-cell {
			display: inline-block;
			width: 60px;
			height: 24px;
			margin: 1px;
			padding: 2px 4px;
			background-color: #1a2a4a;
			color: #88aacc;
			font-size: 11px;
		}
		.grid-cell:hover {
			background-color: #2a4a6a;
			transition: background-color 0.1s;
		}

		/* --- Section: Deep Nesting --- */
		.deep-section {
			padding: 6px;
			background-color: #1a0f1a;
			margin-bottom: 8px;
		}
		.nest-level {
			padding: 4px;
			margin: 2px;
			background-color: #221133;
			border-left: 2px #443366;
		}
		.nest-leaf {
			padding: 3px 6px;
			color: #bb88ff;
			font-size: 12px;
		}

		/* --- Section: Styled Text --- */
		.text-section {
			padding: 6px;
			background-color: #0f1a0f;
			margin-bottom: 8px;
		}
		.text-block {
			padding: 4px;
			margin-bottom: 2px;
		}
		.text-bold {
			font-weight: bold;
			color: #ffcc00;
		}
		.text-dim {
			color: #666688;
		}
		.text-bright {
			color: #00ff88;
		}

		/* --- Section: Colored Boxes --- */
		.boxes-section {
			padding: 6px;
			background-color: #1a1a0f;
			margin-bottom: 8px;
		}
		.color-box {
			display: inline-block;
			width: 28px;
			height: 28px;
			margin: 2px;
		}
		.color-box:hover {
			width: 32px;
			height: 32px;
			transition: width 0.2s, height 0.2s;
		}

		/* --- Section: Scrolling --- */
		.scroll-section {
			padding: 6px;
			background-color: #0f0f1a;
			max-height: 150px;
			overflow: auto;
		}
		.scroll-item {
			padding: 4px 8px;
			margin-bottom: 1px;
			background-color: #1a1a2e;
		}
	</style>
</head>
<body>
	<div class="container" id="perf-root">
		<h1 id="perf-title">RmlUI Performance Stress Test</h1>

		<!-- Section 1: Simple List (50 items) -->
		<h2>List (50 items)</h2>
		<div class="list-section" id="list-section">
			<div class="list-item" id="li-001">List item 001 - Lorem ipsum dolor sit amet</div>
			<div class="list-item" id="li-002">List item 002 - Consectetur adipiscing elit</div>
			<div class="list-item" id="li-003">List item 003 - Sed do eiusmod tempor</div>
			<div class="list-item" id="li-004">List item 004 - Incididunt ut labore et dolore</div>
			<div class="list-item" id="li-005">List item 005 - Magna aliqua ut enim ad</div>
			<div class="list-item" id="li-006">List item 006 - Minim veniam quis nostrud</div>
			<div class="list-item" id="li-007">List item 007 - Exercitation ullamco laboris</div>
