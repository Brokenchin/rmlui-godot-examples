				<div class="grid-cell">R5C3</div>
				<div class="grid-cell">R5C4</div>
				<div class="grid-cell">R5C5</div>
				<div class="grid-cell">R5C6</div>
				<div class="grid-cell">R5C7</div>
			</div>
			<div class="grid-row">
				<div class="grid-cell">R6C0</div>
				<div class="grid-cell">R6C1</div>
				<div class="grid-cell">R6C2</div>
				<div class="grid-cell">R6C3</div>
				<div class="grid-cell">R6C4</div>
				<div class="grid-cell">R6C5</div>
				<div class="grid-cell">R6C6</div>
				<div class="grid-cell">R6C7</div>
			</div>
			<div class="grid-row">
				<div class="grid-cell">R7C0</div>
				<div class="grid-cell">R7C1</div>
				<div class="grid-cell">R7C2</div>
				<div class="grid-cell">R7C3</div>
				<div class="grid-cell">R7C4</div>
				<div class="grid-cell">R7C5</div>
				<div class="grid-cell">R7C6</div>
				<div class="grid-cell" id="gc-7-7">R7C7</div>
			</div>
		</div>

		<!-- Section 3: Deep Nesting (5 levels x 8 branches = 40+ elements) -->
		<h2>Deep Nesting (5 levels)</h2>
		<div class="deep-section" id="deep-section">
			<div class="nest-level">
				<div class="nest-level">
					<div class="nest-level">
						<div class="nest-level">
							<div class="nest-level"><div class="nest-leaf" id="deep-a1">Leaf A1 (depth 5)</div></div>
							<div class="nest-level"><div class="nest-leaf">Leaf A2 (depth 5)</div></div>
						</div>
						<div class="nest-level">
							<div class="nest-level"><div class="nest-leaf">Leaf A3 (depth 5)</div></div>
							<div class="nest-level"><div class="nest-leaf">Leaf A4 (depth 5)</div></div>
						</div>
					</div>
					<div class="nest-level">
						<div class="nest-level">
							<div class="nest-level"><div class="nest-leaf">Leaf B1 (depth 5)</div></div>
							<div class="nest-level"><div class="nest-leaf">Leaf B2 (depth 5)</div></div>
						</div>
						<div class="nest-level">
							<div class="nest-level"><div class="nest-leaf">Leaf B3 (depth 5)</div></div>
							<div class="nest-level"><div class="nest-leaf">Leaf B4 (depth 5)</div></div>
						</div>
					</div>
				</div>
				<div class="nest-level">
					<div class="nest-level">
						<div class="nest-level">
							<div class="nest-level"><div class="nest-leaf">Leaf C1 (depth 5)</div></div>
							<div class="nest-level"><div class="nest-leaf">Leaf C2 (depth 5)</div></div>
						</div>
						<div class="nest-level">
							<div class="nest-level"><div class="nest-leaf">Leaf C3 (depth 5)</div></div>
							<div class="nest-level"><div class="nest-leaf">Leaf C4 (depth 5)</div></div>
						</div>
					</div>
					<div class="nest-level">
						<div class="nest-level">
							<div class="nest-level"><div class="nest-leaf">Leaf D1 (depth 5)</div></div>
							<div class="nest-level"><div class="nest-leaf">Leaf D2 (depth 5)</div></div>
						</div>
						<div class="nest-level">
							<div class="nest-level"><div class="nest-leaf">Leaf D3 (depth 5)</div></div>
							<div class="nest-level"><div class="nest-leaf" id="deep-d4">Leaf D4 (depth 5)</div></div>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Section 4: Styled Text (30 blocks) -->
		<h2>Styled Text (30 blocks)</h2>
		<div class="text-section" id="text-section">
			<div class="text-block"><span class="text-bold">Bold text 01</span> mixed with <span class="text-dim">dim text</span> and <span class="text-bright">bright text</span></div>
			<div class="text-block"><span class="text-bold">Bold text 02</span> mixed with <span class="text-dim">dim text</span> and <span class="text-bright">bright text</span></div>
