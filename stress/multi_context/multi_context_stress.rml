			<div class="list-item">List item 014 - Cupidatat non proident sunt</div>
			<div class="list-item">List item 015 - In culpa qui officia deserunt</div>
			<div class="list-item">List item 016 - Mollit anim id est laborum</div>
			<div class="list-item">List item 017 - Ut enim ad minima veniam</div>
			<div class="list-item">List item 018 - Quis nostrum exercitationem</div>
			<div class="list-item">List item 019 - Ullam corporis suscipit</div>
			<div class="list-item">List item 020 - Laboriosam nisi ut aliquid</div>
			<div class="list-item">List item 021 - Ex ea commodi consequatur</div>
			<div class="list-item">List item 022 - Quis autem vel eum iure</div>
			<div class="list-item">List item 023 - Reprehenderit qui in ea</div>
			<div class="list-item">List item 024 - Voluptate velit esse quam</div>
			<div class="list-item">List item 025 - Nihil molestiae consequatur</div>
			<div class="list-item">List item 026 - Vel illum qui dolorem eum</div>
			<div class="list-item">List item 027 - Fugiat quo voluptas nulla</div>
			<div class="list-item">List item 028 - Pariatur at vero eos et</div>
			<div class="list-item">List item 029 - Accusamus et iusto odio</div>
			<div class="list-item">List item 030 - Dignissimos ducimus qui</div>
			<div class="list-item">List item 031 - Blanditiis praesentium</div>
			<div class="list-item">List item 032 - Voluptatum deleniti atque</div>
			<div class="list-item">List item 033 - Corrupti quos dolores et quas</div>
			<div class="list-item">List item 034 - Molestias excepturi sint</div>
			<div class="list-item">List item 035 - Occaecati cupiditate non</div>
			<div class="list-item">List item 036 - Provident similique sunt</div>
			<div class="list-item">List item 037 - In culpa qui officia deserunt</div>
			<div class="list-item">List item 038 - Mollitia animi id est</div>
			<div class="list-item">List item 039 - Laborum et dolorum fuga</div>
			<div class="list-item">List item 040 - Et harum quidem rerum facilis</div>
			<div class="list-item">List item 041 - Est et expedita distinctio</div>
			<div class="list-item">List item 042 - Nam libero tempore cum soluta</div>
			<div class="list-item">List item 043 - Nobis est eligendi optio</div>
			<div class="list-item">List item 044 - Cumque nihil impedit quo minus</div>
			<div class="list-item">List item 045 - Id quod maxime placeat facere</div>
			<div class="list-item">List item 046 - Possimus omnis voluptas</div>
			<div class="list-item">List item 047 - Assumenda est omnis dolor</div>
			<div class="list-item">List item 048 - Repellendus temporibus autem</div>
			<div class="list-item">List item 049 - Quibusdam et aut officiis</div>
			<div class="list-item" id="li-050">List item 050 - Debitis aut rerum necessitatibus</div>
		</div>

		<!-- Section 2: Nested Grid (8x8 = 64 cells) -->
		<h2>Grid (8x8 = 64 cells)</h2>
		<div class="grid-section" id="grid-section">
			<div class="grid-row">
				<div class="grid-cell" id="gc-0-0">R0C0</div>
				<div class="grid-cell">R0C1</div>
				<div class="grid-cell">R0C2</div>
				<div class="grid-cell">R0C3</div>
				<div class="grid-cell">R0C4</div>
				<div class="grid-cell">R0C5</div>
				<div class="grid-cell">R0C6</div>
				<div class="grid-cell">R0C7</div>
			</div>
			<div class="grid-row">
				<div class="grid-cell">R1C0</div>
				<div class="grid-cell">R1C1</div>
				<div class="grid-cell">R1C2</div>
				<div class="grid-cell">R1C3</div>
				<div class="grid-cell">R1C4</div>
